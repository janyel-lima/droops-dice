{
  "name": "D&D Attribute Studio Dev",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "Vue.volar",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint"
      ]
    }
  },
  "forwardPorts": [3000, 8080, 9099, 4000, 9000, 5001, 8085, 9199, 4500, 9150, 4400],
  "postCreateCommand": "npm install && npm install -g firebase-tools",
  "remoteUser": "node"
}
